# --- PostgreSQL ---
POSTGRES_USER=parking
POSTGRES_PASSWORD=parking
POSTGRES_DB=smart_parking
POSTGRES_PORT=5434

# --- Backend (NestJS) ---
DATABASE_URL=postgresql://parking:parking@localhost:5434/smart_parking?schema=public
PORT=3000
JWT_SECRET=change-this-dev-secret-key-min-32-chars
JWT_EXPIRES_IN=8h
# Ventana de tolerancia de reservas (Politica 2). Bajar a 1 para demo en vivo.
RESERVATION_TOLERANCE_MINUTES=20
CORS_ORIGIN=http://localhost:5173

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3000
